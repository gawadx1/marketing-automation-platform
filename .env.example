# PostgreSQL
POSTGRES_USER=marketing_user
POSTGRES_PASSWORD=marketing_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=marketing_platform

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET_KEY=super-secret-key-change-in-production-abc123
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=Marketing Automation Platform
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=DEBUG

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Cache
CACHE_TTL_SECONDS=300

# --- Google Ads API ---
# Set these to use real Google Ads API. Leave empty for simulated data.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Meta Ads API ---
# Set to use real Meta Ads API. Leave empty for simulated data.
META_ADS_ACCESS_TOKEN=
META_ADS_AD_ACCOUNT_ID=
META_ADS_APP_ID=
META_ADS_APP_SECRET=

# --- HubSpot CRM API ---
# Set to use real HubSpot API. Leave empty for simulated data.
HUBSPOT_ACCESS_TOKEN=

# --- Mailchimp API ---
# Set these to use real Mailchimp API. Leave empty for simulated data.
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=

# --- Google Analytics Data API ---
# Set these to use real GA4 API. Leave empty for simulated data.
GOOGLE_ANALYTICS_CREDENTIALS_JSON=
GOOGLE_ANALYTICS_PROPERTY_ID=

# Prometheus
PROMETHEUS_ENABLED=true
