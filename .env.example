# PostgreSQL
POSTGRES_USER=marketing_user
POSTGRES_PASSWORD=marketing_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=marketing_platform

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET_KEY=super-secret-key-change-in-production-abc123
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=Marketing Automation Platform
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=DEBUG

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Cache
CACHE_TTL_SECONDS=300

# Prometheus
PROMETHEUS_ENABLED=true
